#!/usr/bin/env python3
"""
Тестовый бот для проверки всей системы.
Работает с очень маленькими объемами.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent.parent))

from src.core.base_bot import TradingBot


class TestBot(TradingBot):
    """Тестовый бот с минимальными объемами"""
    
    def __init__(self):
        config = {
            'exchange': 'bybit',
            'symbol': 'ETHUSDT',  # используем ETH для теста
            
            # Минимальные параметры
            'tp': 0.01,  # 1% (очень маленький)
            'sl': 0.01,  # 1%
            'timeframe': 5,
            'qty': 5,  # 5 USDT (минимально возможное)
            'leverage': 1,
            'max_positions': 1,
            
            # Простая стратегия
            'strategy': 'ma_crossover',
            'strategy_params': {
                'short_ma': 14,
                'long_ma': 45
            },
            
            # Либеральные риск-параметры
            'risk_params': {
                'max_drawdown': 10.0,
                'max_consecutive_losses': 5,
                'max_daily_loss': 20.0,
                'max_position_size': 50.0
            }
        }
        
        super().__init__('TEST_BOT', config)


if __name__ == "__main__":
    print("=" * 70)
    print("🧪 ЗАПУСК ТЕСТОВОГО БОТА")
    print("=" * 70)
    print("⚠️  Бот работает с реальными деньгами, но с минимальными объемами")
    print("    Нажмите Ctrl+C для остановки")
    print("=" * 70)
    
    bot = TestBot()
    try:
        bot.run()
    except KeyboardInterrupt:
        print("\n👋 Тестовый бот остановлен")
    except Exception as e:
        print(f"❌ Ошибка: {e}")
        import traceback
        traceback.print_exc()