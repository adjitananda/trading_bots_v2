#!/usr/bin/env python3
"""
Бот для торговли BTCUSDT.
Параметры из старой системы: MACD стратегия, timeframe=30
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent.parent))

# Принудительно добавляем проект в PYTHONPATH
os.environ["PYTHONPATH"] = str(Path(__file__).parent.parent) + ":" + os.environ.get("PYTHONPATH", "")

from src.core.base_bot import TradingBot


class BTCUSDTBot(TradingBot):
    """Бот для торговли BTCUSDT (MACD стратегия)"""
    
    def __init__(self):
        config = {
            'exchange': 'bybit',
            'symbol': 'BTCUSDT',
            
            # Торговые параметры (из старой системы)
            'tp': 0.020,  # 2.0% (BTC менее волатилен)
            'sl': 0.015,  # 1.5%
            'timeframe': 30,  # 30 минут
            'qty': 50,  # 50 USDT
            'leverage': 1,
            'max_positions': 1,
            
            # Стратегия MACD
            'strategy': 'macd',
            'strategy_params': {
                'fast': 8,     # Быстрая EMA
                'slow': 21,    # Медленная EMA
                'signal': 9    # Сигнальная линия
            },
            
            # Риск-параметры
            'risk_params': {
                'max_drawdown': 3.0,  # Для BTC меньше просадка
                'max_consecutive_losses': 3,
                'max_daily_loss': 100.0,  # 100 USDT
                'max_position_size': 500.0  # 500 USDT
            },
            
            'intervals': {
                'status_log': 300,
                'risk_check': 60,
                'closed_check': 30,
                'snapshot': 3600
            }
        }
        
        super().__init__('BTCUSDT', config)


if __name__ == "__main__":
    bot = BTCUSDTBot()
    try:
        bot.run()
    except KeyboardInterrupt:
        print("\n👋 Бот остановлен")
    except Exception as e:
        print(f"❌ Критическая ошибка: {e}")
        import traceback
        traceback.print_exc()