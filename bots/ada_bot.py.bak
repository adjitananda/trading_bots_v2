#!/usr/bin/env python3
"""
Бот для торговли ADAUSDT.
Параметры из старой системы: timeframe=3, short_ma=5, long_ma=20
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent.parent))

from src.core.base_bot import TradingBot


class ADAUSDTBot(TradingBot):
    """Бот для торговли ADAUSDT (очень быстрый)"""
    
    def __init__(self):
        config = {
            'exchange': 'bybit',
            'symbol': 'ADAUSDT',
            
            # Торговые параметры (из старой системы)
            'tp': 0.050,  # 5.0%
            'sl': 0.030,  # 3.0%
            'timeframe': 3,  # 3 минуты (очень быстрый)
            'qty': 5,  # 5 USDT
            'leverage': 1,
            'max_positions': 1,
            
            # Стратегия MA crossover с короткими MA
            'strategy': 'ma_crossover',
            'strategy_params': {
                'short_ma': 5,   # Очень короткая
                'long_ma': 20     # Короткая
            },
            
            # Риск-параметры
            'risk_params': {
                'max_drawdown': 5.0,
                'max_consecutive_losses': 3,
                'max_daily_loss': 15.0,  # 15 USDT
                'max_position_size': 25.0  # 25 USDT
            },
            
            'intervals': {
                'status_log': 300,
                'risk_check': 60,
                'closed_check': 30,
                'snapshot': 3600
            }
        }
        
        super().__init__('ADAUSDT', config)


if __name__ == "__main__":
    bot = ADAUSDTBot()
    try:
        bot.run()
    except KeyboardInterrupt:
        print("\n👋 Бот остановлен")
    except Exception as e:
        print(f"❌ Критическая ошибка: {e}")
        import traceback
        traceback.print_exc()