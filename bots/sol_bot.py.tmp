#!/usr/bin/env python3
"""
Бот для торговли SOLUSDT.
Параметры из старой системы: MA (9, 29)
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent.parent))

# Принудительно добавляем проект в PYTHONPATH
os.environ["PYTHONPATH"] = str(Path(__file__).parent.parent) + ":" + os.environ.get("PYTHONPATH", "")

from src.core.base_bot import TradingBot


class SOLUSDTBot(TradingBot):
    """Бот для торговли SOLUSDT"""
    
    def __init__(self):
        config = {
            'exchange': 'bybit',
            'symbol': 'SOLUSDT',
            
            # Торговые параметры (из старой системы)
            'tp': 0.050,  # 5.0%
            'sl': 0.005,  # 0.5% (очень маленький SL!)
            'timeframe': 5,
            'qty': 10,
            'leverage': 1,
            'max_positions': 1,
            
            # Стратегия MA crossover
            'strategy': 'ma_crossover',
            'strategy_params': {
                'short_ma': 9,
                'long_ma': 29
            },
            
            'risk_params': {
                'max_drawdown': 5.0,
                'max_consecutive_losses': 3,
                'max_daily_loss': 30.0,
                'max_position_size': 50.0
            },
            
            'intervals': {
                'status_log': 300,
                'risk_check': 60,
                'closed_check': 30,
                'snapshot': 3600
            }
        }
        
        super().__init__('SOLUSDT', config)


if __name__ == "__main__":
    bot = SOLUSDTBot()
    try:
        bot.run()
    except KeyboardInterrupt:
        print("\n👋 Бот остановлен")
    except Exception as e:
        print(f"❌ Критическая ошибка: {e}")
        import traceback
        traceback.print_exc()